# Copy to .env and fill in. .env is gitignored — never commit real credentials.

# ---- Jira (see .claude/skills/jira/SKILL.md) ----
# Only needed if you're not using the Atlassian Remote MCP server (preferred).
JIRA_BASE_URL=https://yourteam.atlassian.net
JIRA_EMAIL=you@company.com
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=PROJ
# Classic ("company-managed") Jira projects only — team-managed projects don't need this.
# Find it with: curl -s -u "$JIRA_EMAIL:$JIRA_API_TOKEN" "$JIRA_BASE_URL/rest/api/3/field" | jq -r '.[] | select(.name=="Epic Link") | .id'
#JIRA_EPIC_LINK_FIELD=customfield_10014
# Override only if your Jira site renamed the default issue types.
#JIRA_ISSUE_TYPE_EPIC=Epic
#JIRA_ISSUE_TYPE_STORY=Story
#JIRA_ISSUE_TYPE_SUBTASK=Subtask
#JIRA_ISSUE_TYPE_BUG=Bug

# ---- GitHub MCP server (see .mcp.json) ----
# The gh CLI (already used by /review-pr) covers PR review/merge on its own — this is only
# needed for agents/environments that want the GitHub MCP server's structured tools instead.
# Needs at least `repo` scope. This must be exported in your actual shell env (not just
# .env) since Claude Code substitutes it into .mcp.json at startup — e.g.:
#   export GITHUB_PERSONAL_ACCESS_TOKEN=$(gh auth token)
GITHUB_PERSONAL_ACCESS_TOKEN=

# =====================================================================
# All variables below back the ~40 additional MCP servers in .mcp.json —
# see docs/MCP_SERVERS.md for what each server actually needs and its
# readiness status. Leave any of these blank/commented if you don't use
# that server; an unset var just makes that one server fail to start.
# Remember: export these in your shell (`set -a; source .env; set +a`),
# .env alone is not read by Claude Code's ${VAR} substitution.
# =====================================================================

# ---- Git ----
#GITLAB_PERSONAL_ACCESS_TOKEN=
#GITLAB_API_URL=https://gitlab.com/api/v4

# ---- DevOps ----
#KUBECONFIG=~/.kube/config
#AWS_PROFILE=
#AWS_REGION=us-east-1
#GOOGLE_APPLICATION_CREDENTIALS=~/.config/gcloud/application_default_credentials.json
#GCP_PROJECT_ID=
#VERCEL_API_TOKEN=

# ---- Database ----
#POSTGRES_CONNECTION_STRING=postgresql://user:pass@localhost:5432/service_archetype
#MYSQL_HOST=localhost
#MYSQL_PORT=3306
#MYSQL_USER=
#MYSQL_PASS=
#MYSQL_DB=
#MDB_MCP_CONNECTION_STRING=mongodb://localhost:27017
#REDIS_HOST=localhost
#REDIS_PORT=6379
#REDIS_PASSWORD=

# ---- Search & Research ----
#CONTEXT7_API_KEY=
#FIRECRAWL_API_KEY=
#TAVILY_API_KEY=
#EXA_API_KEY=
#PERPLEXITY_API_KEY=

# ---- Communication ----
#SLACK_BOT_TOKEN=
#SLACK_TEAM_ID=
#DISCORD_TOKEN=
# gmail / google-calendar: OAuth flow on first run — no static token here.

# ---- Data Platform ----
#KAFKA_BROKERS=localhost:9092
#OPENSEARCH_URL=https://localhost:9200
#OPENSEARCH_USERNAME=
#OPENSEARCH_PASSWORD=
#ES_URL=https://localhost:9200
#ES_API_KEY=
#SNOWFLAKE_ACCOUNT=
#SNOWFLAKE_USER=
#SNOWFLAKE_PASSWORD=
#DATABRICKS_HOST=
#DATABRICKS_TOKEN=

# ---- AI ----
#OPENAI_API_KEY=
#HF_TOKEN=
#OLLAMA_HOST=http://localhost:11434

# ---- Monitoring ----
#GRAFANA_URL=http://localhost:3000
#GRAFANA_API_KEY=
#PROMETHEUS_URL=http://localhost:9090

# ---- Productivity ----
#OBSIDIAN_API_KEY=
#OBSIDIAN_HOST=http://localhost:27123
# figma / chrome-devtools: no credentials, need the Figma desktop app / Chrome respectively.
