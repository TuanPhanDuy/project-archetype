# Copy to .env and fill in. .env is gitignored — never commit real credentials.

# ---- Jira (see .claude/skills/jira/SKILL.md) ----
# Only needed if you're not using the Atlassian Remote MCP server (preferred).
JIRA_BASE_URL=https://yourteam.atlassian.net
JIRA_EMAIL=you@company.com
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=PROJ
# Classic ("company-managed") Jira projects only — team-managed projects don't need this.
# Find it with: curl -s -u "$JIRA_EMAIL:$JIRA_API_TOKEN" "$JIRA_BASE_URL/rest/api/3/field" | jq -r '.[] | select(.name=="Epic Link") | .id'
#JIRA_EPIC_LINK_FIELD=customfield_10014
# Override only if your Jira site renamed the default issue types.
#JIRA_ISSUE_TYPE_EPIC=Epic
#JIRA_ISSUE_TYPE_STORY=Story
#JIRA_ISSUE_TYPE_SUBTASK=Subtask
#JIRA_ISSUE_TYPE_BUG=Bug
