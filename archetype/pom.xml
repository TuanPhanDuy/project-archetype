<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <!--
      Maven archetype that scaffolds a new service from this reference project.

      Build/install:   ./sync.sh && mvn -f archetype/pom.xml clean install
      Generate:        mvn archetype:generate \
                         -DarchetypeGroupId=com.onemount \
                         -DarchetypeArtifactId=service-archetype \
                         -DarchetypeVersion=0.1.0

      The archetype copies every file RAW (filtered=false) and a post-generate Groovy
      script renames the package / groupId / artifactId / version — so the heavy ${...}
      and ## usage in yaml/workflows/k6/markdown is preserved byte-for-byte.
    -->
    <groupId>com.onemount</groupId>
    <artifactId>service-archetype</artifactId>
    <version>0.1.0</version>
    <packaging>maven-archetype</packaging>
    <name>service-archetype (Maven archetype)</name>
    <description>Archetype for the Spring Boot 4 / Java 25 service archetype</description>

    <build>
        <extensions>
            <extension>
                <groupId>org.apache.maven.archetype</groupId>
                <artifactId>archetype-packaging</artifactId>
                <version>3.4.0</version>
            </extension>
        </extensions>
    </build>
</project>
